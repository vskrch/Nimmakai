# ── Client-facing auth ──────────────────────────────────────────────
# Comma-separated list of accepted proxy API keys.
# Required unless ALLOW_INSECURE_AUTH=true (local dev only).
PROXY_API_KEYS=sk-nimmakai-local-dev

# Set true only for local/dev when PROXY_API_KEYS is empty (accepts any Bearer).
# ALLOW_INSECURE_AUTH=false

# ── NVIDIA NIM upstream ─────────────────────────────────────────────
# Base URL for NVIDIA's hosted OpenAI-compatible API
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Comma-separated NVIDIA NIM API keys (one per account).
# Each key typically has ~40 requests/minute on free tier.
NIM_API_KEYS=nvapi-key-1,nvapi-key-2,nvapi-key-3,nvapi-key-4

# Per-key rate limit (requests per minute). Free tier is usually 40.
NIM_RPM_LIMIT=40

# Safety buffer: treat limit as slightly lower to avoid 429s (0.0–1.0)
NIM_RPM_SAFETY_FACTOR=0.9

# Cooldown (seconds) after a 429 before a key is eligible again
NIM_COOLDOWN_SECONDS=60

# Soft daily request budget per key (UTC calendar day)
NIM_RPD_LIMIT=2000

# Multi-provider (OpenRouter-style). Built-in nim uses NIM_* above.
# Free providers auto-register when these env vars are set (keys only — URLs from presets).
# Or add any OpenAI-compatible endpoint in the dashboard: Providers → free presets / Custom.
# PROVIDERS_CONFIG_PATH=config/providers.yaml
#
# Durable SQLite store (providers + preferences). Mount a volume on this path in production.
# SQLITE_PATH=.nimmakai/nimmakai.db
# SQLITE_SEED_FREE_PRESETS=true
#
# OpenCode Zen (best free coding models: mimo-v2.5-free, deepseek-v4-flash-free, …)
# OPENCODE_ZEN_API_KEYS=...
# OPENCODE_API_KEYS=...
#
# GROQ_API_KEYS=gsk-...
# CEREBRAS_API_KEYS=...
# OPENROUTER_API_KEYS=sk-or-...
# GEMINI_API_KEYS=...
# TOGETHER_API_KEYS=...
# FIREWORKS_API_KEYS=...
# SAMBANOVA_API_KEYS=...
# DEEPINFRA_API_KEYS=...
# GITHUB_MODELS_API_KEYS=ghp_...
# MISTRAL_API_KEYS=...
# HYPERBOLIC_API_KEYS=...

# Comma-separated CORS origins (default * allows all)
# CORS_ALLOW_ORIGINS=*

# Max concurrent in-flight requests per key
NIM_MAX_IN_FLIGHT_PER_KEY=3

# Global in-flight cap (0 = auto: keys × per-key)
GLOBAL_MAX_IN_FLIGHT=0

# ── Intelligent routing ─────────────────────────────────────────────
# Set false to restore bootstrap passthrough-only behavior
ROUTING_ENABLED=true

# Path to versioned model catalog (aliases, intent chains)
MODELS_CONFIG_PATH=config/models.yaml

# rules_only (default) | rules_then_llm
CLASSIFY_MODE=rules_only

# Fall back to next chain model when an explicit org/model fails
ENABLE_FALLBACK_ON_EXPLICIT=true

# Cap ordered model attempts per request
MAX_MODEL_FALLBACKS=6

# Refresh live GET /v1/models interval (seconds)
CATALOG_REFRESH_SECONDS=300

# Run capability probes every N catalog refreshes (not every cycle)
PROBE_EVERY_N_REFRESHES=6

# NVIDIA docs catalog (B) + gentle probes (C)
CATALOG_DOCS_URL=https://build.nvidia.com/models.md
CATALOG_FETCH_DOCS=true
CATALOG_RUN_PROBES=true
# Keep probe budget low to avoid clogging free-tier RPM
PROBE_BUDGET_PER_HOUR=8
CATALOG_SNAPSHOT_PATH=.nimmakai/catalog_snapshot.json

# Inject synthetic nimmakai/auto into GET /v1/models
INJECT_AUTO_MODEL=true

# ── Account safety ──────────────────────────────────────────────────
SAFETY_JITTER_ENABLED=true
SAFETY_JITTER_MS_MIN=20
SAFETY_JITTER_MS_MAX=120

AUTH_FAIL_THRESHOLD=2
AUTH_QUARANTINE_SECONDS=3600

STICKY_SESSIONS_ENABLED=true
STICKY_SESSION_TTL_SECONDS=1800

# Optional corporate egress proxy (NOT for ban evasion — your responsibility)
# NIM_EGRESS_PROXIES=http://user:pass@proxy.corp:8080
# HTTPS_PROXY=

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Request timeout to upstream NIM (seconds)
UPSTREAM_TIMEOUT=300

# Streaming / adaptive routing (Cursor-friendly, no artificial delay)
# Short TTFT = skip non-responding models fast; long idle once streaming
# STREAM_TTFT_TIMEOUT_SECONDS=12
# STREAM_IDLE_TIMEOUT_SECONDS=180
# ADAPTIVE_ROUTING=true
# SAFETY_JITTER_ENABLED=false
# REQUEST_LOG_SIZE=200

# Default model if client omits one (optional; auto routing preferred)
# DEFAULT_MODEL=meta/llama-3.1-70b-instruct
