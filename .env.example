# ── Client-facing auth ──────────────────────────────────────────────
# Any non-empty key clients (Cursor, OpenCode, etc.) may send.
# Comma-separated list of accepted proxy API keys. Leave empty to accept any key.
PROXY_API_KEYS=sk-nimmakai-local-dev

# ── NVIDIA NIM upstream ─────────────────────────────────────────────
# Base URL for NVIDIA's hosted OpenAI-compatible API
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Comma-separated NVIDIA NIM API keys (one per account).
# Each key typically has ~40 requests/minute on free tier.
NIM_API_KEYS=nvapi-key-1,nvapi-key-2,nvapi-key-3,nvapi-key-4

# Per-key rate limit (requests per minute). Free tier is usually 40.
NIM_RPM_LIMIT=40

# Safety buffer: treat limit as slightly lower to avoid 429s (0.0–1.0)
NIM_RPM_SAFETY_FACTOR=0.9

# Cooldown (seconds) after a 429 before a key is eligible again
NIM_COOLDOWN_SECONDS=60

# Soft daily request budget per key (UTC calendar day)
NIM_RPD_LIMIT=2000

# Max concurrent in-flight requests per key
NIM_MAX_IN_FLIGHT_PER_KEY=3

# Global in-flight cap (0 = auto: keys × per-key)
GLOBAL_MAX_IN_FLIGHT=0

# ── Intelligent routing ─────────────────────────────────────────────
# Set false to restore bootstrap passthrough-only behavior
ROUTING_ENABLED=true

# Path to versioned model catalog (aliases, intent chains)
MODELS_CONFIG_PATH=config/models.yaml

# rules_only (default) | rules_then_llm
CLASSIFY_MODE=rules_only

# Fall back to next chain model when an explicit org/model fails
ENABLE_FALLBACK_ON_EXPLICIT=true

# Cap ordered model attempts per request
MAX_MODEL_FALLBACKS=3

# Refresh live GET /v1/models interval (seconds)
CATALOG_REFRESH_SECONDS=300

# Inject synthetic nimmakai/auto into GET /v1/models
INJECT_AUTO_MODEL=true

# ── Account safety ──────────────────────────────────────────────────
SAFETY_JITTER_ENABLED=true
SAFETY_JITTER_MS_MIN=20
SAFETY_JITTER_MS_MAX=120

AUTH_FAIL_THRESHOLD=2
AUTH_QUARANTINE_SECONDS=3600

STICKY_SESSIONS_ENABLED=true
STICKY_SESSION_TTL_SECONDS=1800

# Optional corporate egress proxy (NOT for ban evasion — your responsibility)
# NIM_EGRESS_PROXIES=http://user:pass@proxy.corp:8080
# HTTPS_PROXY=

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Request timeout to upstream NIM (seconds)
UPSTREAM_TIMEOUT=300

# Default model if client omits one (optional; auto routing preferred)
# DEFAULT_MODEL=meta/llama-3.1-70b-instruct
